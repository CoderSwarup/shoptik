# Application
PORT=5001

# Database — PostgreSQL
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DB_URL="postgresql://shoptik:your_password@localhost:5432/shoptik_db"

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# gRPC — Go service connection
GRPC_SERVICE_URL=localhost:5003
