# Application
PORT=5001

# Database — PostgreSQL
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DB_URL="postgresql://shoptik:your_password@localhost:5432/shoptik_db"

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# gRPC — Go service connection
GRPC_SERVICE_URL=localhost:5003

# Redis — for Pub/Sub notifications and BullMQ queue
REDIS_URL=redis://:your_password@localhost:6379

# BullMQ Queue Settings
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=3
QUEUE_BACKOFF_DELAY=1000
