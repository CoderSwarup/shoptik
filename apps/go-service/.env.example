# Application
HTTP_PORT=5002
GRPC_PORT=5003

# MongoDB
MONGO_URI=mongodb://admin:your_password@localhost:27018/shoptik?authSource=admin
MONGO_DB=shoptik

# Redis — for Pub/Sub notifications and BullMQ queue consumer
REDIS_URL=redis://:your_password@localhost:6379

# Order Logs Consumer Settings
ORDER_LOGS_BATCH_SIZE=50
ORDER_LOGS_BATCH_DELAY_MS=2000
