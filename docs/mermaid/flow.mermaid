flowchart TD
    %% Frontend Clients
    subgraph Frontend["Frontend Next.js"]
        U[User Dashboard]
        A[Admin Portal]
        AL[Order Logs Terminal SSE]
    end

    %% Backend Services
    subgraph Backend["Backend Services"]
        N[NestJS API Port 5001]
        OG[OrderLogsGateway SSE]
        G[Go Service 5002-5003]
    end

    %% Databases
    subgraph Data["Data Layer"]
        P[(PostgreSQL)]
        M[(MongoDB)]
    end

    %% Messaging Layer
    subgraph Messaging["Messaging Layer"]
        R[Redis Streams]
        C[Cursor Storage]
    end

    %% User Flow - Address Validation
    U -->|POST addresses| N
    N -->|gRPC GetDeliveryZoneByPincode| G
    G -->|Query| M
    M -->|Zone data| G
    G -->|Response| N
    N -->|Save Address| P
    N -->|Response| U

    %% Admin Flow - Manage Delivery Zones
    A -->|CRUD delivery-zones| N
    N -->|gRPC DeliveryZoneService| G
    G -->|CRUD| M
    G -->|Response| N
    N -->|Response| A

    %% Order Flow with Event Logging
    U -->|POST orders| N
    N -->|gRPC Validate Address| G
    G -->|Query| M
    G -->|Response| N
    N -->|Save Order| P
    
    %% Order Event Logging Flow
    N -->|XADD| R
    R -->|XREAD with cursor| G
    G -->|Batch 50 logs or 2s| M
    G -.->|Save cursor| C
    
    %% SSE Streaming Flow
    AL -.->|SSE Connection| OG
    OG -->|Poll every 2s gRPC| G
    G -->|GetRecentLogs| M
    M -->|Return logs| G
    G -->|Stream logs| OG
    OG -->|text event stream| AL

    %% Real-time Notifications
    G -.->|WebSocket| U
    G -.->|WebSocket| A
