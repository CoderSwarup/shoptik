# ============================================================================
# Production Environment Configuration
# COPY THIS FILE TO .env.prod AND UPDATE WITH SECURE VALUES
# ============================================================================

# PostgreSQL Configuration (USE STRONG PASSWORDS!)
POSTGRES_USER=shoptik
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
POSTGRES_DB=shoptik_db

# MongoDB Configuration (USE STRONG PASSWORDS!)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_mongo_password
MONGO_DB=shoptik

# Redis Configuration (USE STRONG PASSWORD!)
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# Application Configuration
NODE_ENV=production
GO_ENV=production

# Application Ports (Internal Docker Network)
GO_HTTP_PORT=5002
GO_GRPC_PORT=5003
NESTJS_PORT=5001
WEB_PORT=3000

# CORS Configuration (Production - Update with your domain)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Build Configuration
BUILD_VERSION=latest
GIT_COMMIT=unknown
